# App
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/debales_webhooks

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Action config (used by the HTTP Notify action - point this at
# https://webhook.site to watch outbound calls during your Loom recording)
NOTIFY_WEBHOOK_URL=https://webhook.site/your-unique-url

# Simulate downstream CRM flakiness (0.0 - 1.0 probability of failure).
# Set to 0 for a clean demo run, raise it to show failure + replay.
CRM_FAILURE_RATE=0.3
